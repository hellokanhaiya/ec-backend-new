### Database
SPRING_DATASOURCE_URL=jdbc:h2:mem:ecommerce_db;MODE=MySQL;DB_CLOSE_DELAY=-1;DATABASE_TO_UPPER=false
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver

### Local development mail option
### Mailtrap Sandbox (testing only; emails appear inside the Mailtrap inbox)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=40a0ac64810b7b
MAIL_PASSWORD=<paste-your-mailtrap-sandbox-password>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
APP_MAIL_FROM=no-reply@ecommerce.local

### Production low-cost email option
### Amazon SES SMTP endpoint example:
### email-smtp.us-east-1.amazonaws.com
# MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=your-ses-smtp-username
# MAIL_PASSWORD=your-ses-smtp-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
# APP_MAIL_FROM=verified-sender@yourdomain.com
